# --- Public app (never use NEXT_PUBLIC_* for secrets) ---
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NODE_ENV=development
NEXT_BUILD_ID=local
# Vercel Blob — server only. Required for catalog + markdown reads/writes.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin UI + /api/admin/* — server only. Sign in at /admin (httpOnly cookie) or send header x-admin-secret.
ADMIN_API_SECRET=your-long-random-string